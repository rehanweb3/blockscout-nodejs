# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
BACKEND_PORT=3001

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/blockscout

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb://localhost:27017/blockscout

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave empty to auto-start a local Redis instance
REDIS_URL=

# ── Blockchain Node ───────────────────────────────────────────────────────────
RPC_URL=https://rpc.yourchain.example.com
WS_URL=wss://websocket.yourchain.example.com
CHAIN_ID=1

# ── Indexer ───────────────────────────────────────────────────────────────────
ENABLE_INDEXER=true
LOG_LEVEL=info

# ── Admin Panel ───────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme
ADMIN_JWT_SECRET=change_this_to_a_long_random_secret_before_production
